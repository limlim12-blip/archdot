{
    "allowDuplicates": false,
    "historyFile": "clipboard_history.json",
    "maxHistory": 100,
    "deleteAfter": 0,
    "logFile": "clipse.log",
    "pollInterval": 50,
    "maxEntryLength": 65,
    "themeFile": "custom_theme.json",
    "tempDir": "tmp_files",
    "keyBindings": {
        "choose": "enter,o,O",
        "clearSelected": "S",
        "down": "down,j",
        "end": "end",
        "filter": "/,f",
        "forceQuit": "Q",
        "home": "home",
        "more": "?",
        "nextPage": "right,l",
        "prevPage": "left,h",
        "preview": "space",
        "quit": "q,esc",
        "remove": "backspace,d",
        "selectDown": "shift+down,J",
        "selectSingle": "s",
        "selectUp": "shift+up,K",
        "togglePin": "p",
        "togglePinned": "tab",
        "up": "up,k",
        "yankFilter": "ctrl+s"
    },
    "imageDisplay": {
        "type": "kitty",
        "scaleX": 20,
        "scaleY": 20,
        "heightCut": 2
    },
    "excludedApps": [
        "1Password",
        "Bitwarden",
        "KeePassXC",
        "LastPass",
        "Dashlane",
        "Password Safe",
        "Keychain Access"
    ],
    "autoPaste": {
        "enabled": false,
        "keybind": "ctrl+v",
        "buffer": 10
    },
    "enableMouse": true,
    "enableDescription": false
}
